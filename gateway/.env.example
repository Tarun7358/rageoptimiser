PORT=6002
HOST=0.0.0.0
NODE_ENV=production

# Telemetry Auth Token (Rage Optimiser Agent uses this)
MONITORING_AUTH_TOKEN=default_telemetry_token
GATEWAY_AGENT_TOKEN=default_telemetry_token

# Dashboard JWT signature secret
JWT_SECRET=super_secret_dashboard_jwt

# Database storage path
SQLITE_PATH=./gateway.sqlite
DATABASE_PATH=./gateway.sqlite
