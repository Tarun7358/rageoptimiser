# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
GUILD_ID=your_default_guild_id_here
OWNER_ID=your_discord_user_id_here
GOOGLE_APPLICATION_CREDENTIALS="./firebase-key.json"

# Clutch Music Bot Config (separate bot)
MUSIC_CLIENT_ID=your_music_client_id_here
MUSIC_BOT_PERMISSIONS=36700160

# Network Ports
PORT=5000
WS_PORT=5001

# Auth Secrets
JWT_SECRET=use_a_strong_random_secret_key_here
DASHBOARD_PASSWORD=set_a_fallback_owner_dashboard_password_here

# Token Encryption (AES-256-GCM) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts Discord OAuth access tokens stored in discord_sessions table.
# REQUIRED in production. If unset, a derived fallback is used (insecure).
TOKEN_ENCRYPTION_KEY=generate_64_hex_chars_here

# Internal Service Secret — shared between backend and music bot for /api/internal/* endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=generate_a_random_secret_here

# URLs (update for production)
FRONTEND_URL=http://localhost:4680
DASHBOARD_URL=http://localhost:4680
OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/discord/callback
